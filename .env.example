# ============= CodeBuddy SDK 认证 =============
# 必须配置以下任一项来使用 AI 功能

# 方式一：API Key（推荐用于生产部署）
CODEBUDDY_API_KEY=your_api_key_here

# 方式二：Auth Token
# CODEBUDDY_AUTH_TOKEN=your_auth_token_here

# ============= 服务器配置 =============
# 服务器端口（云平台通常通过环境变量自动设置）
PORT=3000

# 运行模式（生产环境设为 production）
NODE_ENV=production

# ============= 可选配置 =============
# 网络环境（国内/国际）
# CODEBUDDY_INTERNET_ENVIRONMENT=domestic

# 自定义 API 基础 URL
# CODEBUDDY_BASE_URL=https://your-custom-endpoint.com
